# Rust / Cargo build output
/target/
**/target/

# Compiled WASM artifacts (regenerated by the build)
*.wasm

# Soroban test execution snapshots (regenerated by `cargo test`)
test_snapshots/

# Backup files produced by rustfmt
**/*.rs.bk

# Editor / IDE
.idea/
.vscode/
*.swp

# OS noise
.DS_Store
Thumbs.db

# NOTE: Cargo.lock is intentionally NOT ignored — it is committed so contract
# builds are fully reproducible across machines and CI.
